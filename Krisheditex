}

nav a{
color:white;
margin-left:20px;
text-decoration:none;
font-weight:bold;
}

.hero{
text-align:center;
padding:80px 20px;
}

.hero img{
width:170px;
height:170px;
border-radius:50%;
border:5px solid #00ffd5;
box-shadow:0 0 25px #00ffd5;
object-fit:cover;
}

.hero h1{
font-size:40px;
margin-top:20px;
}

.typing{
color:#00ffd5;
font-size:24px;
margin-top:10px;
}

section{
padding:60px 20px;
text-align:center;
}

.card{
background:rgba(0,0,0,0.6);
padding:30px;
border-radius:15px;
max-width:800px;
margin:auto;
margin-top:30px;
}

.skills{
max-width:600px;
margin:auto;
}

.skill{
margin:20px 0;
text-align:left;
}

.skill-bar{
background:#333;
border-radius:20px;
overflow:hidden;
}

.skill-fill{
height:14px;
background:#00ffd5;
width:0;
animation:fill 3s forwards;
}

@keyframes fill{
from{width:0}
}

.html{width:95%}
.css{width:90%}
.js{width:80%}
.react{width:70%}
.node{width:65%}
.ui{width:85%}

.project{
background:#111;
padding:20px;
margin:20px auto;
border-radius:10px;
max-width:500px;
transition:0.3s;
}

.project:hover{
transform:scale(1.05);
}

form input,form textarea{
width:100%;
padding:10px;
margin:10px 0;
border-radius:6px;
border:none;
}

button{
background:#00ffd5;
border:none;
padding:12px 20px;
border-radius:6px;
font-weight:bold;
cursor:pointer;
}

.social a{
display:inline-block;
margin:10px;
color:#00ffd5;
text-decoration:none;
font-weight:bold;
}

footer{
background:#00000080;
padding:20px;
margin-top:40px;
}

@media(max-width:600px){

.hero h1{
font-size:28px;
}

nav{
flex-direction:column;
}

}

</style>
</head>

